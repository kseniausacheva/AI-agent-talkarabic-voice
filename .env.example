# Шаблон для docker-compose / Coolify. Скопируй в .env и заполни.
# В Coolify эти же переменные задаются через UI в разделе Environment Variables.

# ===== LLM =====
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=minimax/minimax-m3

# ===== Публичные URL =====
# Backend domain (например https://api.talkarabic.app)
BACKEND_PUBLIC_URL=https://api.example.com
# Frontend domain (например https://talkarabic.app)
FRONTEND_PUBLIC_URL=https://app.example.com
