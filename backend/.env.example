# ===== OpenRouter (LLM) =====
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=minimax/minimax-m3
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Опционально: для статистики на openrouter
OPENROUTER_APP_NAME=talkarabic-voice
OPENROUTER_APP_URL=http://localhost:3000

# ===== Whisper (Speech-to-Text) =====
# Варианты: openai/whisper-small (500MB, плохо для арабского),
#           openai/whisper-medium (1.5GB, ок для арабского/русского),
#           openai/whisper-large-v3 (3GB, лучше всего)
WHISPER_MODEL=openai/whisper-small
# Язык для транскрипции: ar (арабский), ru (русский), en (английский), auto
WHISPER_LANGUAGE=ru
WHISPER_DEVICE=cpu

# ===== App =====
ENVIRONMENT=development
MAX_AUDIO_DURATION_SECONDS=120
LOG_LEVEL=INFO

# ===== CORS =====
# Через запятую. Для прод укажи URL фронта на Vercel
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== Auth (Спринт 2) =====
# Секрет для подписи JWT. В проде — длинная случайная строка (например, openssl rand -hex 32)
AUTH_SECRET=dev-secret-change-me
# Инвайт-коды для регистрации. Пустое значение = регистрация с этой ролью выключена
INVITE_CODE=school-invite-2026
ADMIN_INVITE_CODE=admin-invite-2026

# ===== База данных =====
# Путь к файлу SQLite (директория создаётся автоматически)
DATABASE_PATH=data/app.db

# ===== Google Sheets (вебхук Apps Script) =====
# Пусто = интеграция выключена. Настройка: docs/GSHEETS_SETUP.md
GSHEETS_WEBHOOK_URL=
GSHEETS_SECRET=
